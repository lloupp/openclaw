{
  "agents": {
    "defaults": {
      "model": {
        "primary": "google/gemini-1.5-flash"
      }
    }
  },
  "models": {
    "providers": {
      "google": {
        "apiKey": "${GOOGLE_GENERATIVE_AI_API_KEY}"
      }
    }
  },
  "channels": {
    "telegram": {
      "dmPolicy": "open",
      "allowFrom": ["*"]
    }
  }
}
